{
  "name": "@sven/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./integrations/*": {
      "types": "./dist/integrations/*.d.ts",
      "import": "./dist/integrations/*.js",
      "default": "./dist/integrations/*.js"
    },
    "./integrations/*.js": {
      "types": "./dist/integrations/*.d.ts",
      "import": "./dist/integrations/*.js",
      "default": "./dist/integrations/*.js"
    },
    "./nats/*": {
      "types": "./dist/nats/*.d.ts",
      "import": "./dist/nats/*.js",
      "default": "./dist/nats/*.js"
    },
    "./nats/*.js": {
      "types": "./dist/nats/*.d.ts",
      "import": "./dist/nats/*.js",
      "default": "./dist/nats/*.js"
    },
    "./sdk/*": {
      "types": "./dist/sdk/*.d.ts",
      "import": "./dist/sdk/*.js",
      "default": "./dist/sdk/*.js"
    },
    "./sdk/*.js": {
      "types": "./dist/sdk/*.d.ts",
      "import": "./dist/sdk/*.js",
      "default": "./dist/sdk/*.js"
    }
  },
  "typesVersions": {
    "*": {
      "integrations/*.js": [
        "dist/integrations/*.d.ts"
      ],
      "integrations/*": [
        "dist/integrations/*.d.ts"
      ],
      "nats/*.js": [
        "dist/nats/*.d.ts"
      ],
      "nats/*": [
        "dist/nats/*.d.ts"
      ],
      "sdk/*.js": [
        "dist/sdk/*.d.ts"
      ],
      "sdk/*": [
        "dist/sdk/*.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@types/htmlparser2": "^3.10.7",
    "fastify": "^5.8.5",
    "htmlparser2": "^9.1.0",
    "nats": "^2.29.3"
  }
}
