{
  "name": "@sven/trading-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Autonomous trading platform: market data pipeline, trading engine, risk management, OMS, prediction models, and news intelligence for Sven.",
  "exports": {
    "./market-data": {
      "types": "./src/market-data/index.ts",
      "import": "./dist/market-data/index.js",
      "default": "./dist/market-data/index.js"
    },
    "./engine": {
      "types": "./src/engine/index.ts",
      "import": "./dist/engine/index.js",
      "default": "./dist/engine/index.js"
    },
    "./risk": {
      "types": "./src/risk/index.ts",
      "import": "./dist/risk/index.js",
      "default": "./dist/risk/index.js"
    },
    "./oms": {
      "types": "./src/oms/index.ts",
      "import": "./dist/oms/index.js",
      "default": "./dist/oms/index.js"
    },
    "./predictions": {
      "types": "./src/predictions/index.ts",
      "import": "./dist/predictions/index.js",
      "default": "./dist/predictions/index.js"
    },
    "./news": {
      "types": "./src/news/index.ts",
      "import": "./dist/news/index.js",
      "default": "./dist/news/index.js"
    },
    "./autonomous": {
      "types": "./src/autonomous/index.ts",
      "import": "./dist/autonomous/index.js",
      "default": "./dist/autonomous/index.js"
    },
    "./broker": {
      "types": "./src/broker/index.ts",
      "import": "./dist/broker/index.js",
      "default": "./dist/broker/index.js"
    },
    "./backtest": {
      "types": "./src/backtest/index.ts",
      "import": "./dist/backtest/index.js",
      "default": "./dist/backtest/index.js"
    },
    "./analytics": {
      "types": "./src/analytics/index.ts",
      "import": "./dist/analytics/index.js",
      "default": "./dist/analytics/index.js"
    },
    "./alerts": {
      "types": "./src/alerts/index.ts",
      "import": "./dist/alerts/index.js",
      "default": "./dist/alerts/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config jest.config.cjs --passWithNoTests",
    "test:coverage": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config jest.config.cjs --coverage"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "typescript": "catalog:"
  }
}
