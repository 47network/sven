{
  "name": "@sven/model-router",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Multi-model inference routing, model registry, benchmarking, agency orchestration, and VRAM budget management for Sven.",
  "exports": {
    "./registry": {
      "types": "./src/registry/index.ts",
      "import": "./dist/registry/index.js",
      "default": "./dist/registry/index.js"
    },
    "./router": {
      "types": "./src/router/index.ts",
      "import": "./dist/router/index.js",
      "default": "./dist/router/index.js"
    },
    "./agency": {
      "types": "./src/agency/index.ts",
      "import": "./dist/agency/index.js",
      "default": "./dist/agency/index.js"
    },
    "./benchmark": {
      "types": "./src/benchmark/index.ts",
      "import": "./dist/benchmark/index.js",
      "default": "./dist/benchmark/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
