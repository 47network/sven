{
  "name": "@sven/proactive-notifier",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Proactive notification engine — lets Sven autonomously reach out via Slack, Discord, WhatsApp, or any adapter channel",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
