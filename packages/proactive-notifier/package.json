      "types": "./src/triggers/index.ts",
      "import": "./src/triggers/index.ts",
      "default": "./src/triggers/index.ts"
    },
    "./channels": {
      "types": "./src/channels/index.ts",
      "import": "./src/channels/index.ts",
      "default": "./src/channels/index.ts"
    },
    "./engine": {
      "types": "./src/engine/index.ts",
      "import": "./src/engine/index.ts",
      "default": "./src/engine/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "@types/uuid": "^10.0.0",
    "nats": "^2.19.0",
    "pg": "^8.11.0",
    "uuid": "^10.0.0"
  }
}
