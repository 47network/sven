# ═══════════════════════════════════════════════════════════════════════
# Sven Multi-VM — VM14 (daedalus) Environment
# Copy to .env.vm14 and replace all placeholder values.
#
# VM14 hosts:
#   - the47network.com static website (port 80, behind VM1 TLS proxy)
#   - plate.the47network.com static website (port 8080)
#   - Sven public API gateway (port 4000, proxied by VM1)
# ═══════════════════════════════════════════════════════════════════════

# ── Network Topology ──
VM14_INTERNAL_IP=10.47.47.14
VM1_INTERNAL_IP=10.47.47.5
VM4_INTERNAL_IP=10.47.47.8
VM5_INTERNAL_IP=10.47.47.9
VM13_INTERNAL_IP=10.47.47.13

# ── Static Website ──
THE47NETWORK_WEBROOT=/var/www/the47network.com
PLATE_WEBROOT=/var/www/plate.the47network.com
NGINX_WORKER_PROCESSES=auto
NGINX_WORKER_CONNECTIONS=1024

# ── Public API (optional — enable when ready) ──
PUBLIC_API_ENABLED=false
PUBLIC_API_PORT=4000
PUBLIC_API_UPSTREAM_HOST=10.47.47.8
PUBLIC_API_UPSTREAM_PORT=3000
PUBLIC_API_RATE_LIMIT_RPS=30
PUBLIC_API_RATE_LIMIT_BURST=60

# ── NATS (connect to VM4 cluster) ──
NATS_URL=nats://10.47.47.8:4222

# ── Logging ──
LOG_LEVEL=info
LOG_FORMAT=json

# ── Container Registry ──
REGISTRY=ghcr.io/47network/sven
NGINX_TAG=stable-alpine
