# ═══════════════════════════════════════════════════════════════════════
# Sven Multi-VM — VM6 Data & Observability Environment
# Copy to .env.vm6 and replace all placeholder values.
# ═══════════════════════════════════════════════════════════════════════

# ── Network Topology ──
VM4_INTERNAL_IP=10.74.47.8
VM5_INTERNAL_IP=10.74.47.9
VM6_INTERNAL_IP=10.74.47.10

# ── PostgreSQL (on VM4) ──
POSTGRES_USER=sven
POSTGRES_PASSWORD=replace-with-production-postgres-password
POSTGRES_DB=sven

# ── NATS (on VM4) ──
NATS_PORT=4222

# ── Gateway (on VM4) ──
GATEWAY_PORT=3000
SVEN_ADAPTER_TOKEN=replace-with-production-adapter-token

# ── OpenSearch ──
OPENSEARCH_INITIAL_ADMIN_PASSWORD=replace-with-production-opensearch-password
OPENSEARCH_JAVA_OPTS=-Xms1g -Xmx1g
OPENSEARCH_PORT=9200

# ── SearXNG ──
SEARXNG_SECRET_KEY=replace-with-production-searxng-secret

# ── RAG ──
RAG_EMBEDDINGS_MODEL=nomic-embed-text:latest
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_REINDEX_ON_BOOT=false
RAG_INGEST_GIT_REPOS=
RAG_INGEST_NAS_PATHS=
RAG_INGEST_NOTES_PATHS=

# ── Monitoring ──
PROMETHEUS_RETENTION_DAYS=30
GRAFANA_ADMIN_PASSWORD=replace-with-production-grafana-password
LOKI_RETENTION_PERIOD=168h
LOKI_STORAGE_DIR=/var/lib/sven/loki

# ── Container Registry ──
REGISTRY=ghcr.io/47network/sven
RAG_INDEXER_TAG=latest
RAG_NAS_INGESTOR_TAG=latest
RAG_GIT_INGESTOR_TAG=latest
RAG_NOTES_INGESTOR_TAG=latest
SEARXNG_TAG=latest
EGRESS_PROXY_TAG=latest
OTEL_COLLECTOR_TAG=0.102.1
PROMETHEUS_TAG=v2.54.1
GRAFANA_TAG=11.5.2
LOKI_TAG=2.9.4
PROMTAIL_TAG=2.9.4
OPENSEARCH_TAG=2.18.0

# ── Host Storage Paths ──
SVEN_PROD_OPENSEARCH_DIR=/srv/sven/prod/data/opensearch
SVEN_PROD_PROMETHEUS_DIR=/srv/sven/prod/data/prometheus
SVEN_PROD_GRAFANA_DIR=/srv/sven/prod/data/grafana
SVEN_PROD_LOKI_DIR=/srv/sven/prod/data/loki
SVEN_PROD_LOKI_COLD_DIR=/srv/sven/prod/data/loki-cold
SVEN_PROD_EGRESS_PROXY_DIR=/srv/sven/prod/data/egress-proxy
