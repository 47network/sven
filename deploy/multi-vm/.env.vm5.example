# ═══════════════════════════════════════════════════════════════════════
# Sven Multi-VM — VM5 AI & Voice Environment
# Copy to .env.vm5 and replace all placeholder values.
# ═══════════════════════════════════════════════════════════════════════

# ── Network Topology ──
VM4_INTERNAL_IP=10.74.47.8
VM5_INTERNAL_IP=10.74.47.9
VM6_INTERNAL_IP=10.74.47.10

# ── PostgreSQL (on VM4) ──
POSTGRES_USER=sven
POSTGRES_PASSWORD=replace-with-production-postgres-password
POSTGRES_DB=sven

# ── Gateway (on VM4) ──
GATEWAY_PORT=3000
SVEN_ADAPTER_TOKEN=replace-with-production-adapter-token

# ── LiteLLM ──
LITELLM_MASTER_KEY=replace-with-production-litellm-master-key

# ── Provider Keys (populate as needed) ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
AZURE_API_KEY=
MISTRAL_API_KEY=

# ── Voice Services ──
VOICE_TRANSCRIPT_RETENTION_DAYS=30
FASTER_WHISPER_LANGUAGE=auto
FASTER_WHISPER_DEVICE=auto
VOICE_TTS_PROVIDER=piper
VOICE_TTS_CHANNELS=discord,slack,telegram,teams,google_chat,whatsapp,signal,imessage,webchat
VOICE_TTS_RETENTION_DAYS=7
VOICE_TTS_MAX_CHARS=1200
PIPER_VOICE=alloy
HF_TOKEN=

# ── Container Registry ──
REGISTRY=ghcr.io/47network/sven
FASTER_WHISPER_TAG=latest
PIPER_TAG=latest
WAKE_WORD_TAG=latest

# ── Host Storage Paths ──
SVEN_PROD_TTS_DIR=/srv/sven/prod/data/tts
SVEN_PROD_WAKE_WORD_DIR=/srv/sven/prod/data/wake-word
SVEN_PROD_OLLAMA_DIR=/srv/sven/prod/data/ollama

# ── Container-Internal Paths ──
VOICE_TTS_STORAGE=/var/lib/sven/tts
WAKE_WORD_STORAGE=/var/lib/sven/wake-word
