# ═══════════════════════════════════════════════════════════════════════
# Sven Multi-VM — VM7 Adapters Environment
# Copy to .env.vm7 and replace all placeholder values.
# ═══════════════════════════════════════════════════════════════════════

# ── Network Topology ──
VM4_INTERNAL_IP=10.74.47.8
VM7_INTERNAL_IP=10.74.47.11

# ── Gateway (on VM4) ──
GATEWAY_PORT=3000
SVEN_ADAPTER_TOKEN=replace-with-production-adapter-token

# ── Channel Tokens (populate the ones you deploy) ──
DISCORD_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
MATRIX_HOMESERVER_URL=
MATRIX_ACCESS_TOKEN=
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
SIGNAL_CLI_REST_API=
GOOGLE_CHAT_CREDENTIALS=
IRC_SERVER=
IRC_NICKNAME=
IRC_CHANNELS=
WEBCHAT_ALLOWED_ORIGINS=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_CHANNEL=
NOSTR_PRIVATE_KEY=
NOSTR_RELAYS=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
ZALO_APP_ID=
ZALO_SECRET_KEY=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
MATTERMOST_URL=
MATTERMOST_BOT_TOKEN=
IMESSAGE_BRIDGE_URL=
NEXTCLOUD_URL=
NEXTCLOUD_TOKEN=
TLON_SHIP_URL=
TLON_ACCESS_KEY=
VOICE_CALL_SIP_SERVER=
VOICE_CALL_SIP_USER=
VOICE_CALL_SIP_PASSWORD=

# ── Cloudflare Tunnel ──
CLOUDFLARED_TOKEN=replace-with-cloudflared-tunnel-token

# ── Mirror Agent ──
MIRROR_ENABLED=false

# ── Container Registry ──
REGISTRY=ghcr.io/47network/sven
ADAPTER_TAG=latest
CLOUDFLARED_TAG=latest
MIRROR_TAG=latest
