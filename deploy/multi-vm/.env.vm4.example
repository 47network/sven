# ═══════════════════════════════════════════════════════════════════════
# Sven Multi-VM — VM4 Platform Environment
# Copy to .env.vm4 and replace all placeholder values.
# ═══════════════════════════════════════════════════════════════════════

# ── Network Topology ──
VM4_INTERNAL_IP=10.74.47.8
VM5_INTERNAL_IP=10.74.47.9
VM6_INTERNAL_IP=10.74.47.10
VM7_INTERNAL_IP=10.74.47.11

# ── PostgreSQL ──
POSTGRES_USER=sven
POSTGRES_PASSWORD=replace-with-production-postgres-password
POSTGRES_DB=sven

# ── NATS ──
# No additional config needed — defaults to JetStream

# ── Gateway API ──
GATEWAY_PORT=3000
COOKIE_SECRET=replace-with-64-char-production-cookie-secret
SVEN_ADAPTER_TOKEN=replace-with-production-adapter-token
CORS_ORIGIN=https://sven.the47network.com
ADMIN_USERNAME=47
ADMIN_PASSWORD=replace-with-production-admin-password

# ── OpenSearch (on VM6) ──
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=replace-with-production-opensearch-password

# ── Embeddings (via Ollama on VM5) ──
EMBEDDINGS_ENABLED=true
EMBEDDINGS_PROVIDER=ollama
EMBEDDINGS_MODEL=nomic-embed-text
EMBEDDINGS_DIM=768

# ── bridge-47dynamics (gRPC) ──
SVEN_BRIDGE_SERVICE_TOKEN=replace-with-production-bridge-token
SVEN_BRIDGE_ORG_ID=47dynamics-legacy-org
SVEN_BRIDGE_CHAT_ID=47dynamics-hq
SVEN_BRIDGE_AGENT_ID=47dynamics-copilot
SVEN_BRIDGE_REQUIRE_TENANT_MAPPING=false

# ── Container Registry ──
REGISTRY=ghcr.io/47network/sven
GATEWAY_API_TAG=latest
AGENT_RUNTIME_TAG=latest
SKILL_RUNNER_TAG=latest
REGISTRY_WORKER_TAG=latest
NOTIFICATION_SERVICE_TAG=latest
WORKFLOW_EXECUTOR_TAG=latest
BRIDGE_TAG=latest

# ── Host Storage Paths ──
SVEN_PROD_ARTIFACTS_DIR=/srv/sven/prod/data/artifacts
SVEN_PROD_NAS_DIR=/srv/sven/prod/data/nas
SVEN_PROD_INTEGRATIONS_DIR=/srv/sven/prod/data/integrations
SVEN_PROD_GIT_DIR=/srv/sven/prod/data/git
SVEN_PROD_BACKUPS_DIR=/srv/sven/prod/backups
SVEN_REGISTRY_ROOT=/srv/sven/prod/data/skills

# ── Container-Internal Paths ──
SVEN_STORAGE_ROOT=/var/lib/sven/artifacts
ARTIFACT_STORAGE_ROOT=/var/lib/sven/artifacts
SVEN_NAS_ROOT=/var/lib/sven/nas
SVEN_INTEGRATION_STORAGE_ROOT=/var/lib/sven/integrations
GIT_INGEST_CLONE_ROOT=/var/lib/sven/git
