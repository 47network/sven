{
  "title": "Sven Parity Production Gates",
  "tags": [
    "sven",
    "parity",
    "production"
  ],
  "timezone": "Europe/Bucharest",
  "panels": [
    {
      "title": "Core Service Availability",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "up{job=~'gateway-api|agent-runtime|skill-runner|nats'}",
          "legendFormat": "{{job}}"
        }
      ],
      "options": {
        "colorMode": "background",
        "textMode": "auto"
      }
    },
    {
      "title": "Gateway p95 Latency",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "gateway p95"
        }
      ]
    },
    {
      "title": "HTTP 5xx Rate",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "expr": "rate(http_requests_total{status=~'5..'}[5m])",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "title": "NATS Pending Messages",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "nats_jetstream_consumer_pending_messages",
          "legendFormat": "{{stream}}/{{consumer}}"
        }
      ]
    },
    {
      "title": "Outbox Pending",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "sven_outbox_pending",
          "legendFormat": "pending"
        }
      ],
      "options": {
        "colorMode": "value",
        "textMode": "value"
      }
    },
    {
      "title": "Backpressure Active",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 8
      },
      "targets": [
        {
          "expr": "sven_backpressure_active",
          "legendFormat": "backpressure"
        }
      ],
      "options": {
        "colorMode": "background",
        "textMode": "auto"
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s"
}
