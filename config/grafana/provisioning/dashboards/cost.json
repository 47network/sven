{
  "title": "Sven Cost Dashboard",
  "tags": [
    "sven",
    "cost",
    "llm",
    "tokens"
  ],
  "timezone": "Europe/Bucharest",
  "panels": [
    {
      "title": "Total Token Usage (24h)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "increase(llm_tokens_input_total[24h]) + increase(llm_tokens_output_total[24h])",
          "legendFormat": "Total Tokens"
        }
      ],
      "options": {
        "colorMode": "background",
        "textMode": "auto"
      }
    },
    {
      "title": "Estimated Cost (24h $)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "expr": "increase(llm_cost_dollars_total[24h])",
          "legendFormat": "Cost"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          }
        }
      }
    },
    {
      "title": "Budget Remaining",
      "type": "gauge",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "expr": "1 - (llm_budget_used_dollars / llm_budget_limit_dollars)",
          "legendFormat": "Remaining"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 0.1
              },
              {
                "color": "green",
                "value": 0.3
              }
            ]
          }
        }
      }
    },
    {
      "title": "Token Usage by Model (Rate)",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "rate(llm_tokens_input_total[5m]) * 60",
          "legendFormat": "input {{model}}"
        },
        {
          "expr": "rate(llm_tokens_output_total[5m]) * 60",
          "legendFormat": "output {{model}}"
        }
      ]
    },
    {
      "title": "Cost by Model (Rate $/hr)",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "expr": "rate(llm_cost_dollars_total[5m]) * 3600",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      }
    },
    {
      "title": "Requests by Model (24h)",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "expr": "increase(llm_requests_total[24h])",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "title": "Average Cost per Request",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "expr": "rate(llm_cost_dollars_total[5m]) / rate(llm_requests_total[5m])",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      }
    }
  ],
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "refresh": "5m"
}
