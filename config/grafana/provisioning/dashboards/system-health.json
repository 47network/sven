{
  "title": "Sven System Health",
  "tags": [
    "sven",
    "system",
    "overview"
  ],
  "timezone": "Europe/Bucharest",
  "panels": [
    {
      "title": "Service Health Status",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "up{job=~'gateway-api|agent-runtime|skill-runner|faster-whisper|piper'}",
          "legendFormat": "{{job}}"
        }
      ],
      "options": {
        "colorMode": "background",
        "textMode": "auto"
      }
    },
    {
      "title": "NATS Queue Depth",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "nats_jetstream_consumer_pending_messages",
          "legendFormat": "{{stream}}-{{consumer}}"
        }
      ]
    },
    {
      "title": "Database Connections",
      "type": "graph",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "pg_connections_active",
          "legendFormat": "Active Connections"
        }
      ]
    },
    {
      "title": "API Response Times (p95)",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "title": "Error Rate (5m)",
      "type": "graph",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "expr": "rate(http_requests_total{status=~'5..'}[5m])",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "title": "Outbox Items Pending",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "expr": "sven_outbox_pending",
          "legendFormat": "Pending Items"
        }
      ]
    },
    {
      "title": "Message Throughput (msgs/sec)",
      "type": "graph",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 12
      },
      "targets": [
        {
          "expr": "rate(sven_messages_total[1m])",
          "legendFormat": "{{channel}}"
        }
      ]
    },
    {
      "title": "Tool Execution Time (p50,p95,p99)",
      "type": "graph",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(sven_tool_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(sven_tool_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(sven_tool_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    }
  ],
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "version": 1
}
