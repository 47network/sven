# Development defaults (non-secret template)
ENVIRONMENT=development
NODE_ENV=development
SVEN_DEPLOYMENT_MODE=development
DATABASE_URL=
NATS_URL=
COOKIE_SECRET=
GATEWAY_PORT=3000
POSTGRES_DB=sven_dev
CORS_ORIGIN=http://localhost:3002
SVEN_INTEGRATION_RUNTIME_EXEC_ENABLED=false
SVEN_INTEGRATION_DEPLOY_CMD_TEMPLATE=
SVEN_INTEGRATION_STOP_CMD_TEMPLATE=
SVEN_INTEGRATION_STATUS_CMD_TEMPLATE=
SVEN_INTEGRATION_RUNTIME_RECONCILE_ENABLED=false
SVEN_INTEGRATION_RUNTIME_RECONCILE_INTERVAL_MS=60000
SVEN_INTEGRATION_RUNTIME_AUTOHEAL=false
SVEN_NATIVE_MODE=false
SVEN_NATIVE_SHELL_PATH=
SVEN_NATIVE_SHELL_ALLOWLIST=pwd,ls,dir,echo,cat,type,rg,git,node,npm,pnpm,yarn,python,python3,Get-ChildItem,Get-Content
SVEN_NATIVE_SHELL_ALLOWED_ROOTS=
SVEN_NATIVE_FS_ALLOWED_ROOTS=
SVEN_NATIVE_FS_WALK_USE_RG=true
SVEN_NATIVE_CAPTURE_OUTPUT_DIR=
SVEN_NATIVE_CAPTURE_ALLOWED_ROOTS=

# ── AI Model Providers ───────────────────────────────────────────────
# See docs/integrations/ai-provider-subscriptions.md for full setup guide.

# Google Gemini (AI Studio key — aistudio.google.com/apikey)
GOOGLE_API_KEY=
# Gemini CLI skill (same value as GOOGLE_API_KEY is fine; or leave blank to use OAuth mount)
GEMINI_API_KEY=

# GitHub Copilot API (Pro / Pro+ required)
# Create a Classic PAT at github.com/settings/tokens with `copilot` scope
GITHUB_COPILOT_TOKEN=

# GitHub Token (any account — used for GitHub Models free tier)
GITHUB_TOKEN=

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Mistral
MISTRAL_API_KEY=

# ── Agent Model Routing ───────────────────────────────────────────────
SVEN_AGENT_DEFAULT_MODEL=gpt-4o
SVEN_AGENT_CODING_MODEL=coding
SVEN_AGENT_FAST_MODEL=coding-fast

# LiteLLM proxy master key (required; generate strong random value)
LITELLM_MASTER_KEY=

# Channel adapters (compose contract template)
