# Sven production v1 on Linux VM
# Copy to /srv/sven/prod/env/.env.production and replace placeholder values.

ENVIRONMENT=production
NODE_ENV=production
SVEN_DEPLOYMENT_MODE=production

# Public URLs
SVEN_PUBLIC_BASE_URL=https://sven.systems
SVEN_ADMIN_BASE_URL=https://admin.sven.systems
CORS_ORIGIN=https://sven.systems

# Core ports and credentials
GATEWAY_PORT=3000
POSTGRES_USER=sven
POSTGRES_PASSWORD=replace-with-production-postgres-password
POSTGRES_DB=sven
DATABASE_URL=postgresql://sven:replace-with-production-postgres-password@postgres:5432/sven
COMMUNITY_DATABASE_URL=postgresql://sven:replace-with-production-postgres-password@postgres:5432/sven
NATS_URL=nats://nats:4222
COOKIE_SECRET=replace-with-64-char-production-cookie-secret
SVEN_ADAPTER_TOKEN=replace-with-production-adapter-token

# Admin bootstrap
ADMIN_USERNAME=47
ADMIN_PASSWORD=replace-with-production-admin-password

# Search / retrieval
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=replace-with-production-opensearch-password
OPENSEARCH_DISABLE_SECURITY=false
SEARXNG_SECRET=replace-with-production-searxng-secret
SEARXNG_URL=http://searxng:8080

# Inference
OLLAMA_URL=http://ollama:11434
EMBEDDINGS_ENABLED=true
EMBEDDINGS_PROVIDER=ollama
EMBEDDINGS_URL=http://ollama:11434
EMBEDDINGS_MODEL=nomic-embed-text
EMBEDDINGS_DIM=768

# Provider keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
LITELLM_MASTER_KEY=replace-with-production-litellm-master-key

# Linux container-internal storage paths
SVEN_STORAGE_ROOT=/var/lib/sven/artifacts
ARTIFACT_STORAGE_ROOT=/var/lib/sven/artifacts
SVEN_NAS_ROOT=/var/lib/sven/nas
SVEN_INTEGRATION_STORAGE_ROOT=/var/lib/sven/integrations
VOICE_TTS_STORAGE=/var/lib/sven/tts
WAKE_WORD_STORAGE=/var/lib/sven/wake-word
GIT_INGEST_CLONE_ROOT=/var/lib/sven/git

# Linux host bind roots consumed by docker-compose.production.linux-vm.yml
SVEN_PROD_ROOT=/srv/sven/prod
SVEN_PROD_DATA_ROOT=/srv/sven/prod/data
SVEN_PROD_POSTGRES_DIR=/srv/sven/prod/data/postgres
SVEN_PROD_PGWAL_DIR=/srv/sven/prod/data/postgres-wal
SVEN_PROD_NATS_DIR=/srv/sven/prod/data/nats
SVEN_PROD_OPENSEARCH_DIR=/srv/sven/prod/data/opensearch
SVEN_PROD_ARTIFACTS_DIR=/srv/sven/prod/data/artifacts
SVEN_PROD_NAS_DIR=/srv/sven/prod/data/nas
SVEN_PROD_INTEGRATIONS_DIR=/srv/sven/prod/data/integrations
SVEN_PROD_TTS_DIR=/srv/sven/prod/data/tts
SVEN_PROD_WAKE_WORD_DIR=/srv/sven/prod/data/wake-word
SVEN_PROD_GIT_DIR=/srv/sven/prod/data/git
SVEN_PROD_BROWSER_PROFILE_DIR=/srv/sven/prod/data/browser-profile
SVEN_PROD_OLLAMA_DIR=/srv/sven/prod/data/ollama
SVEN_PROD_PROMETHEUS_DIR=/srv/sven/prod/data/prometheus
SVEN_PROD_GRAFANA_DIR=/srv/sven/prod/data/grafana
SVEN_PROD_LOKI_DIR=/srv/sven/prod/data/loki
SVEN_PROD_LOKI_ARCHIVE_DIR=/srv/sven/prod/data/loki-archive
SVEN_PROD_SEARXNG_DIR=/srv/sven/prod/data/searxng
SVEN_PROD_TUNNEL_DIR=/srv/sven/prod/data/tunnel
SVEN_PROD_BACKUPS_DIR=/srv/sven/prod/backups

# Optional ingestion roots
NAS_INGEST_ROOT=/var/lib/sven/nas
GIT_INGEST_LOCAL_ROOT=/var/lib/sven/nas/git
NOTES_INGEST_ROOT=/var/lib/sven/nas/notes

# Monitoring
GRAFANA_ADMIN_PASSWORD=replace-with-production-grafana-password

# Conservative production defaults
SVEN_INTEGRATION_RUNTIME_EXEC_ENABLED=false
SVEN_INTEGRATION_RUNTIME_RECONCILE_ENABLED=true
SVEN_INTEGRATION_RUNTIME_RECONCILE_INTERVAL_MS=60000
SVEN_INTEGRATION_RUNTIME_AUTOHEAL=false
