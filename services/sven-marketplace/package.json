{
  "name": "@sven/sven-marketplace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Sven Marketplace Service (port 9478) — listings, checkout, orders, payouts. Backs market.sven.systems. Every sale posts a treasury credit via @sven/treasury.",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@sven/shared": "workspace:*",
    "@sven/treasury": "workspace:*",
    "fastify": "^5.8.5",
    "nats": "^2.29.3",
    "pg": "^8.20.0",
    "uuid": "^10.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.21.0",
    "typescript": "catalog:"
  }
}
