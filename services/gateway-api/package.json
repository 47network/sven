{
  "name": "@sven/gateway-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config jest.config.cjs --passWithNoTests",
    "test:backup-restore": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config jest.config.cjs --runTestsByPath src/__tests__/backup-restore.integration.e2e.ts",
    "test:high-frequency": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config jest.config.cjs --runTestsByPath src/__tests__/high-frequency-api.e2e.ts",
    "test:agents": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config jest.config.cjs --runTestsByPath src/__tests__/agents.e2e.ts",
    "db:migrate": "node dist/db/migrate.js",
    "db:migrate:down": "node dist/db/rollback.js",
    "db:rollback:check": "node dist/db/rollback-check.js",
    "db:migrate:compat": "SVEN_MIGRATION_SKIP_INCOMPATIBLE=1 node dist/db/migrate.js",
    "db:seed": "node dist/db/seed.js"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.0.0",
    "@sven/compute-mesh": "file:../../packages/compute-mesh",
    "@sven/design-system": "file:../../packages/design-system",
    "@sven/document-intel": "file:../../packages/document-intel",
    "@sven/marketing-intel": "file:../../packages/marketing-intel",
    "@sven/model-router": "file:../../packages/model-router",
    "@sven/quantum-sim": "file:../../packages/quantum-sim",
    "@sven/security-toolkit": "file:../../packages/security-toolkit",
    "@sven/shared": "file:../../packages/shared",
    "@sven/trading-platform": "file:../../packages/trading-platform",
    "bcrypt": "^6.0.0",
    "fastify": "^5.7.4",
    "multicast-dns": "^7.2.5",
    "nanoid": "^5.0.0",
    "nats": "^2.19.0",
    "otplib": "^12.0.0",
    "pg": "^8.11.0",
    "tar": "^7.5.9",
    "tweetnacl": "^1.0.3",
    "uuid": "^10.0.0",
    "ws": "^8.20.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@types/bcrypt": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "babel-jest": "^30.2.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.7.0"
  },
  "overrides": {
    "test-exclude": "^7.0.1",
    "glob": "^10.5.0",
    "minimatch": "^10.2.1"
  }
}
