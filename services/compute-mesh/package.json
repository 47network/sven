{
  "name": "@sven/compute-mesh-coordinator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Distributed compute mesh coordinator — Postgres-backed device registry, NATS-based work distribution, AES-256-GCM payload encryption, heartbeat monitoring, and result aggregation.",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "migrate": "node --loader tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@sven/compute-mesh": "workspace:*",
    "@sven/shared": "workspace:*",
    "fastify": "^5.8.5",
    "nats": "^2.29.3",
    "pg": "^8.20.0",
    "uuid": "^14.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.21.0",
    "typescript": "catalog:"
  }
}
