{
  "name": "@sven/proactive-notifier-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Standalone Proactive Notification service for Sven — autonomous event-driven notifications with trigger rules, channel dispatch, rate limiting, quiet hours, and adaptive suppression.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sven/proactive-notifier": "workspace:*",
    "@sven/shared": "workspace:*",
    "fastify": "^5.7.4",
    "nats": "^2.19.0",
    "pg": "^8.11.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.7.0",
    "typescript": "catalog:"
  }
}
