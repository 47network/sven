{
  "realm": "sven",
  "enabled": true,
  "displayName": "Sven SSO Test Realm",
  "roles": {
    "realm": [
      {
        "name": "ops"
      }
    ]
  },
  "clients": [
    {
      "clientId": "sven-gateway",
      "name": "Sven Gateway OIDC Client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "sven-gateway-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://127.0.0.1:3001/v1/auth/sso/oidc/callback",
        "http://localhost:3001/v1/auth/sso/oidc/callback"
      ],
      "webOrigins": [
        "*"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "realm-roles-to-groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "sven-sso-user",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Sven",
      "lastName": "SSO",
      "email": "sven-sso-user@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "sven-sso-pass",
          "temporary": false
        }
      ],
      "realmRoles": [
        "ops"
      ]
    }
  ]
}
