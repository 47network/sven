<?xml version="1.0" encoding="utf-8"?>
<!--
  Home-screen widget layout for Sven.
  RemoteViews IDs are read in SvenWidgetProvider.kt and via home_widget package.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:id="@+id/widget_root" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="12dp" android:background="@drawable/sven_widget_background" android:gravity="center_vertical">

    <!-- Header row: Sven wordmark + updated-at time -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">

        <TextView android:id="@+id/widget_app_name" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Sven" android:textColor="#00D9FF" android:textSize="13sp" android:textStyle="bold" android:fontFamily="sans-serif-medium" />

        <TextView android:id="@+id/widget_updated_at" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--:--" android:textColor="#80FFFFFF" android:textSize="11sp" />

    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="6dp" android:layout_marginBottom="6dp" android:background="#1AFFFFFF" />

    <!-- Latest message preview -->
    <TextView android:id="@+id/widget_message" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="Open Sven to start chatting…" android:textColor="#CCFFFFFF" android:textSize="13sp" android:lineSpacingMultiplier="1.3" android:ellipsize="end" android:maxLines="3" />

    <!-- Footer: username -->
    <TextView android:id="@+id/widget_username" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="" android:textColor="#66FFFFFF" android:textSize="11sp" android:ellipsize="end" android:singleLine="true" />

</LinearLayout>
